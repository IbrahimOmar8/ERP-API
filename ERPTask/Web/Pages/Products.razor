@page "/products"
@namespace ERPTask.Web.Pages
@attribute [Authorize]
@inject Application.Inerfaces.Inventory.IProductService Service

<h1>الأصناف</h1>

<div class="toolbar">
    <input @bind="_search" @bind:event="oninput" placeholder="ابحث..." />
    <button class="btn" @onclick="Load">بحث</button>
</div>

<div class="card">
    <table>
        <thead>
            <tr><th>الكود</th><th>الاسم</th><th>الفئة</th><th>سعر البيع</th><th>الضريبة</th><th>الرصيد</th></tr>
        </thead>
        <tbody>
            @foreach (var p in _items)
            {
                <tr>
                    <td>@p.Sku</td>
                    <td>@p.NameAr</td>
                    <td>@p.CategoryName</td>
                    <td>@p.SalePrice.ToString("N2")</td>
                    <td>@p.VatRate.ToString("N1")%</td>
                    <td>@p.CurrentStock.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<ProductDto> _items = new();
    private string _search = "";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _items = await Service.GetAllAsync(new ProductFilterDto
            { Search = _search, PageNumber = 1, PageSize = 200 });
    }
}
