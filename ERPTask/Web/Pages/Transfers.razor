@page "/transfers"
@namespace ERPTask.Web.Pages
@attribute [Authorize(Roles = $"{Domain.Enums.Roles.Admin},{Domain.Enums.Roles.Manager},{Domain.Enums.Roles.WarehouseKeeper}")]
@inject Application.Inerfaces.Inventory.IStockTransferService Transfers
@inject Application.Inerfaces.Inventory.IWarehouseService Warehouses
@inject Application.Inerfaces.Inventory.IProductService Products
@inject AuthenticationStateProvider AuthState

<h1>تحويلات المخازن</h1>

@if (_error != null)
{
    <div class="alert error">@_error</div>
}

<div class="card">
    <h3>إنشاء تحويل جديد</h3>
    <div class="row">
        <div>
            <label>من مخزن</label>
            <select @bind="_fromId">
                <option value="">اختر</option>
                @foreach (var w in _warehouses)
                {
                    <option value="@w.Id">@w.NameAr</option>
                }
            </select>
        </div>
        <div>
            <label>إلى مخزن</label>
            <select @bind="_toId">
                <option value="">اختر</option>
                @foreach (var w in _warehouses)
                {
                    <option value="@w.Id">@w.NameAr</option>
                }
            </select>
        </div>
    </div>
    <div style="margin-top:8px;">
        <label>ملاحظات</label>
        <input @bind="_notes" />
    </div>
    <div class="toolbar" style="margin-top:8px;">
        <select @bind="_pickProductId">
            <option value="">اختر صنف</option>
            @foreach (var p in _products)
            {
                <option value="@p.Id">@p.NameAr (@p.Sku)</option>
            }
        </select>
        <input type="number" min="0.01" step="0.01" @bind="_pickQty" style="width:90px;" />
        <button class="btn outline" @onclick="AddItem">إضافة</button>
    </div>
    @if (_items.Count > 0)
    {
        <table>
            <thead><tr><th>الصنف</th><th>الكمية</th><th></th></tr></thead>
            <tbody>
            @foreach (var i in _items)
            {
                <tr>
                    <td>@i.NameAr</td>
                    <td>@i.Quantity</td>
                    <td><button class="btn danger" @onclick="@(() => _items.Remove(i))">حذف</button></td>
                </tr>
            }
            </tbody>
        </table>
    }
    <button class="btn success" style="margin-top:8px;" disabled="@(_items.Count == 0 || _saving)" @onclick="Save">حفظ التحويل</button>
</div>

<div class="card">
    <h3>التحويلات السابقة</h3>
    <table>
        <thead>
            <tr><th>الرقم</th><th>من</th><th>إلى</th><th>التاريخ</th><th>الأصناف</th><th>القيمة</th><th>الحالة</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var t in _list)
            {
                <tr>
                    <td>@t.TransferNumber</td>
                    <td>@t.FromWarehouseName</td>
                    <td>@t.ToWarehouseName</td>
                    <td>@t.TransferDate.ToLocalTime():yyyy-MM-dd HH:mm</td>
                    <td>@t.Items.Count</td>
                    <td>@t.TotalValue.ToString("N2")</td>
                    <td>@(t.IsCompleted ? "✅ منفذ" : "⏳ قيد التنفيذ")</td>
                    <td>
                        @if (!t.IsCompleted)
                        {
                            <button class="btn success" @onclick="@(() => Complete(t.Id))">تنفيذ</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<WarehouseDto> _warehouses = new();
    private List<ProductDto> _products = new();
    private List<StockTransferDto> _list = new();
    private List<TempLine> _items = new();
    private string _fromId = "";
    private string _toId = "";
    private string _pickProductId = "";
    private string? _notes;
    private decimal _pickQty = 1;
    private string? _error;
    private bool _saving;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        Guid.TryParse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out _userId);

        _warehouses = await Warehouses.GetAllAsync();
        _products = await Products.GetAllAsync(new ProductFilterDto { PageNumber = 1, PageSize = 500 });
        _list = await Transfers.GetAllAsync();
    }

    private void AddItem()
    {
        if (string.IsNullOrEmpty(_pickProductId) || _pickQty <= 0) return;
        var p = _products.FirstOrDefault(x => x.Id.ToString() == _pickProductId);
        if (p == null) return;
        _items.Add(new TempLine { Id = p.Id, NameAr = p.NameAr, Quantity = _pickQty });
        _pickProductId = "";
        _pickQty = 1;
    }

    private async Task Save()
    {
        _error = null;
        _saving = true;
        try
        {
            await Transfers.CreateAsync(new CreateStockTransferDto
            {
                FromWarehouseId = Guid.Parse(_fromId),
                ToWarehouseId = Guid.Parse(_toId),
                Notes = _notes,
                Items = _items.Select(i => new CreateStockTransferItemDto { ProductId = i.Id, Quantity = i.Quantity }).ToList()
            }, _userId);
            _items.Clear();
            _notes = null;
            _list = await Transfers.GetAllAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task Complete(Guid id)
    {
        try
        {
            await Transfers.CompleteAsync(id, _userId);
            _list = await Transfers.GetAllAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private class TempLine
    {
        public Guid Id { get; set; }
        public string NameAr { get; set; } = "";
        public decimal Quantity { get; set; }
    }
}
