@page "/sales/{Id:guid}"
@namespace ERPTask.Web.Pages
@attribute [Authorize]
@inject Application.Inerfaces.POS.ISaleService Sales
@inject Application.Inerfaces.Egypt.IEInvoiceService EInvoice

@if (_sale == null)
{
    <p>جاري التحميل...</p>
}
else
{
<h1>فاتورة @_sale.InvoiceNumber</h1>

@if (_msg != null)
{
    <div class="alert success">@_msg</div>
}
@if (_error != null)
{
    <div class="alert error">@_error</div>
}

<div class="row">
    <div class="card">
        <h3>التفاصيل</h3>
        <table>
            <tr><th>التاريخ</th><td>@_sale.SaleDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td></tr>
            <tr><th>العميل</th><td>@(_sale.CustomerName ?? "عميل نقدي")</td></tr>
            <tr><th>المخزن</th><td>@_sale.WarehouseName</td></tr>
            <tr><th>المجموع</th><td>@_sale.SubTotal.ToString("N2")</td></tr>
            <tr><th>الخصم</th><td>@_sale.DiscountAmount.ToString("N2")</td></tr>
            <tr><th>الضريبة</th><td>@_sale.VatAmount.ToString("N2")</td></tr>
            <tr><th>الإجمالي</th><td><strong>@_sale.Total.ToString("N2")</strong></td></tr>
            <tr><th>المدفوع</th><td>@_sale.PaidAmount.ToString("N2")</td></tr>
            <tr><th>الباقي</th><td>@_sale.ChangeAmount.ToString("N2")</td></tr>
        </table>
        <div style="margin-top:10px;">
            <a class="btn" target="_blank" href="/api/sales/@_sale.Id/print?format=a4">طباعة A4</a>
            <a class="btn outline" target="_blank" href="/api/sales/@_sale.Id/print?format=thermal">طباعة حرارية</a>
        </div>
    </div>
    <div class="card">
        <h3>الفاتورة الإلكترونية (ETA)</h3>
        @if (string.IsNullOrEmpty(_sale.EInvoiceUuid))
        {
            <p>لم ترسل بعد.</p>
            <button class="btn success" @onclick="SubmitEta" disabled="@_etaBusy">@(_etaBusy ? "جاري الإرسال..." : "إرسال للمصلحة")</button>
        }
        else
        {
            <table>
                <tr><th>UUID</th><td><code style="font-size:11px;">@_sale.EInvoiceUuid</code></td></tr>
                <tr><th>الحالة</th><td>@_sale.EInvoiceStatus</td></tr>
            </table>
            <button class="btn outline" @onclick="RefreshEta" disabled="@_etaBusy">تحديث الحالة</button>
        }
    </div>
</div>

<div class="card" style="margin-top:12px;">
    <h3>الأصناف</h3>
    <table>
        <thead><tr><th>الصنف</th><th>الكمية</th><th>السعر</th><th>الخصم</th><th>الضريبة</th><th>الإجمالي</th></tr></thead>
        <tbody>
        @foreach (var i in _sale.Items)
        {
            <tr>
                <td>@i.ProductNameSnapshot</td>
                <td>@i.Quantity.ToString("N2")</td>
                <td>@i.UnitPrice.ToString("N2")</td>
                <td>@i.DiscountAmount.ToString("N2")</td>
                <td>@i.VatAmount.ToString("N2")</td>
                <td>@i.LineTotal.ToString("N2")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private SaleDto? _sale;
    private string? _error;
    private string? _msg;
    private bool _etaBusy;

    protected override async Task OnParametersSetAsync() => _sale = await Sales.GetByIdAsync(Id);

    private async Task SubmitEta()
    {
        _error = null; _msg = null;
        _etaBusy = true;
        try
        {
            await EInvoice.SubmitSaleAsync(Id);
            _sale = await Sales.GetByIdAsync(Id);
            _msg = "تم إرسال الفاتورة للمصلحة";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _etaBusy = false; }
    }

    private async Task RefreshEta()
    {
        _error = null; _msg = null;
        _etaBusy = true;
        try
        {
            await EInvoice.RefreshStatusAsync(Id);
            _sale = await Sales.GetByIdAsync(Id);
            _msg = "تم تحديث الحالة";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _etaBusy = false; }
    }
}
