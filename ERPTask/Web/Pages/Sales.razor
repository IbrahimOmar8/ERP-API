@page "/sales"
@namespace ERPTask.Web.Pages
@attribute [Authorize]
@inject Application.Inerfaces.Inventory.IWarehouseService Warehouses
@inject Application.Inerfaces.POS.ISaleService Sales

<h1>الفواتير</h1>

<div class="card">
    <table>
        <thead>
            <tr><th>الرقم</th><th>التاريخ</th><th>العميل</th><th>المخزن</th><th>الإجمالي</th><th>ETA</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var s in _items)
            {
                <tr>
                    <td>@s.InvoiceNumber</td>
                    <td>@s.SaleDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(s.CustomerName ?? "عميل نقدي")</td>
                    <td>@s.WarehouseName</td>
                    <td>@s.Total.ToString("N2")</td>
                    <td>@(string.IsNullOrEmpty(s.EInvoiceUuid) ? "—" : "✓")</td>
                    <td>
                        <a class="btn outline" href="/sales/@s.Id">عرض</a>
                        <a class="btn" target="_blank" href="/api/sales/@s.Id/print?format=a4">طباعة</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<SaleDto> _items = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await Sales.GetAllAsync(new SaleFilterDto { PageNumber = 1, PageSize = 50 });
    }
}
