@page "/"
@page "/dashboard"
@namespace ERPTask.Web.Pages
@attribute [Authorize]
@inject IReportService Reports

<h1>لوحة التحكم</h1>

@if (_kpi == null)
{
    <p>جاري التحميل...</p>
}
else
{
    <div class="kpis">
        <Kpi Label="مبيعات اليوم" Value="@FormatMoney(_kpi.TodaySales)" Color="#43a047" Icon="💵" />
        <Kpi Label="فواتير اليوم" Value="@_kpi.TodayInvoiceCount.ToString()" Color="#1976d2" Icon="🧾" />
        <Kpi Label="ربح اليوم" Value="@FormatMoney(_kpi.TodayProfit)" Color="#26a69a" Icon="📈" />
        <Kpi Label="جلسات مفتوحة" Value="@_kpi.OpenSessionCount.ToString()" Color="#ffa000" Icon="🛒" />
    </div>
    <h3 style="margin-top:24px;">الشهر</h3>
    <div class="kpis">
        <Kpi Label="مبيعات الشهر" Value="@FormatMoney(_kpi.MonthSales)" Color="#43a047" Icon="💵" />
        <Kpi Label="فواتير الشهر" Value="@_kpi.MonthInvoiceCount.ToString()" Color="#1976d2" Icon="📜" />
        <Kpi Label="ربح الشهر" Value="@FormatMoney(_kpi.MonthProfit)" Color="#26a69a" Icon="📊" />
        <Kpi Label="قيمة المخزون" Value="@FormatMoney(_kpi.TotalStockValue)" Color="#3949ab" Icon="🏪" />
    </div>
    <h3 style="margin-top:24px;">عام</h3>
    <div class="kpis">
        <Kpi Label="العملاء" Value="@_kpi.CustomerCount.ToString()" Color="#7e57c2" Icon="👥" />
        <Kpi Label="الأصناف" Value="@_kpi.ProductCount.ToString()" Color="#fb8c00" Icon="📦" />
        <Kpi Label="أصناف بحد أدنى" Value="@_kpi.LowStockCount.ToString()" Color="#e53935" Icon="⚠️" />
    </div>

    @if (_top.Count > 0)
    {
        <div class="card" style="margin-top:24px;">
            <h3>الأعلى مبيعاً (آخر 30 يوم)</h3>
            <table>
                <thead><tr><th>الصنف</th><th>الكمية</th><th>الإيرادات</th><th>الربح</th></tr></thead>
                <tbody>
                @foreach (var p in _top)
                {
                    <tr>
                        <td>@p.ProductName</td>
                        <td>@p.QuantitySold</td>
                        <td>@FormatMoney(p.Revenue)</td>
                        <td>@FormatMoney(p.Profit)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
}

@code {
    DashboardKpiDto? _kpi;
    IReadOnlyList<TopProductRow> _top = Array.Empty<TopProductRow>();

    protected override async Task OnInitializedAsync()
    {
        var from = DateTime.UtcNow.AddDays(-30);
        var to = DateTime.UtcNow;
        var dash = Reports.GetDashboardAsync();
        var top = Reports.GetTopProductsAsync(from, to, 10);
        _kpi = await dash;
        _top = await top;
    }

    string FormatMoney(decimal v) => v.ToString("N2") + " ج.م";
}
