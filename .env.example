# Copy to .env then customize before running docker-compose.

# Long random secret (≥32 chars) — used to sign JWT access tokens.
JWT_KEY=CHANGE_ME_TO_A_VERY_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LONG_PLEASE

# Default admin password seeded on first startup.
ADMIN_PASSWORD=Admin@1234

# Public URL the browser uses to reach the API (must match CORS allowed origins).
API_PUBLIC_URL=http://localhost:5000/api

# Public URL the API allows in CORS (set to your domain in production).
WEB_PUBLIC_URL=http://localhost:3000
